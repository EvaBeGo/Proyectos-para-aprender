import json                # el módulo json. JSON es un formato para guardar datos organizados en un fichero de texto 
try:
        with open('book_dict.json', 'r') as f:          # Aqui es para leer la agenda
            book_dict = json.load(f)
except FileNotFoundError:
    book_dict = []

def save_address_book():                                   # Aqui es para guardar en la agenda
    with open('book_dict.json', 'w') as f:            # json.dump convierte tu lista de diccionarios en texto y la guarda. json.load la lee y la convierte de vuelta a lista de diccionarios.
        json.dump(book_dict, f)

def add_contact():                         # Vamos a agregar contactos
    name = input('Nombre: ')
    while True:
        phone_number = input('Telefono: ')
        if phone_number.isdigit() and len(phone_number) == 9:
            break
        else: 
            print('La agenda solo admite numeros telefonicos de 9 digitos')
    while True:
            email = input('Email: ')
            split = email.split('@')
            if len(split) == 2 and split[0] != '' and split[1] != '':
                break
            else:
                print('El correo introducido no es valido')

    contact = {
        'name': name,
        'phone_number': phone_number,
        'email': email
    }
    book_dict.append(contact)
    save_address_book()
    print('👍Contacto guardado!')

    

# Ver todos los contactos
def view_contacts():
    sorted_contacts = sorted(book_dict, key=lambda c: c['name'].lower())
    if len(sorted_contacts) == 0:
        print('Tu agenda aun esta vacia.')
    for contact in sorted_contacts:                
        print(f"\n👤 {contact['name']} | 📞 {contact['phone_number']} | ✉️  {contact['email']}")

# Buscar un contacto por nombre
def search_contact():
    name = input('Que nombre buscas? ')
    found = False
    for contact in book_dict:
        if name.lower() in contact['name'].lower():
            print(f"👤 {contact['name']} | 📞 {contact['phone_number']} | ✉️ {contact['email']}")
            found = True
    if not found:
        print('❌ No se encontró ningún contacto con ese nombre.')

def delete_contact():
    name = input('Que contacto quieres eliminar?')
    for contact in book_dict:
        if contact['name'].lower() == name.lower():
            book_dict.remove(contact)
            save_address_book()
            print(f'{name} eliminado🗑️.')
            return
    print('❌ No se encontró ese contacto.')

def edit_contact():
    view_contacts()
    name = input('Que contacto quieres editar? ')
    contact = None
    for c in book_dict:
        if c['name'].lower() == name.lower():
            contact = c
            break
    if contact is None:
        print('No se ha podido encontrar ese contacto en especifico.')
        return
    new_name = input(f"Nombre nuevo({contact['name']}): ")
    if new_name == '':
        new_name = contact['name']

    while True:
        new_phone = input(f"Telefono nuevo ({contact['phone_number']}): ")
        if new_phone == '':
            new_phone = contact['phone_number']
            break
        if new_phone.isdigit() and len(new_phone) == 9:
            break
        print('❌ El teléfono debe tener exactamente 9 números.')
    while True:
        new_email = input(f"Email Nuevo ({contact['email']}): ")
        if new_email == '':
            new_email = contact['email']
            break
        split = new_email.split('@')
        if len(split) == 2 and split[0] != '' and split[1] != '':
            break
        else:
            print('El correo introducido no es valido')

    contact['name'] = new_name
    contact['phone_number'] = new_phone
    contact['email'] = new_email
    save_address_book()
    print('👍 Contacto actualizado!')

def menu():
    while True:
        print('\n==== AGENDA ====')
        print('1. Añadir contacto')
        print('2. Ver contactos')
        print('3. Buscar contactos')
        print('4. Eliminar contacto')
        print('5. Editar contacto')
        print('6. Salir')
        option = input('Selecciona una opcion: ')
        if option == '1':
            add_contact()
        elif option == '2':
            view_contacts()
        elif option == '3':
            search_contact()
        elif option == '4':
            delete_contact()
        elif option == '5':
            edit_contact()
        elif option == '6':
            print('Hasta luegoo Boniatoo')
            break
        else:
            print('❌ Opcion no valida ❌')

menu()
